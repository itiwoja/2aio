{
  "_comment": "2AIO provider registry — any OpenAI-compatible /chat/completions endpoint works as a delegation/consult target. Add providers here (data, no code). Keys come from env only (never argv/chat/logs). key_env empty = no key needed (e.g. local Ollama). Grok(xai) is just one entry, not special.",
  "default": "openai",
  "providers": {
    "openai":   { "url": "https://api.openai.com/v1/chat/completions",   "model": "gpt-4o",         "key_env": "OPENAI_API_KEY" },
    "xai":      { "url": "https://api.x.ai/v1/chat/completions",         "model": "grok-4-latest",  "key_env": "XAI_API_KEY" },
    "deepseek": { "url": "https://api.deepseek.com/v1/chat/completions", "model": "deepseek-chat",  "key_env": "DEEPSEEK_API_KEY" },
    "groq":     { "url": "https://api.groq.com/openai/v1/chat/completions", "model": "llama-3.3-70b-versatile", "key_env": "GROQ_API_KEY" },
    "ollama":   { "url": "http://localhost:11434/v1/chat/completions",   "model": "qwen2.5:14b",    "key_env": "" }
  }
}
