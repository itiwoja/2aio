{
  "_comment": "2AIO-tuned ruleset for the live harness. Philosophy: block only IRREVERSIBLE / catastrophic actions so the guard stays armed during normal work instead of being disabled for friction. Routine staging (git add -A / git add .) is intentionally NOT blocked. Owner bypasses any block with the ! prefix. Source hook: inoX-Network/claude-code-safety-guard (MIT).",

  "blocked_patterns": [
    "rm\\s+-rf?\\s+/(\\s|$)",
    "rm\\s+-rf?\\s+~(\\s|$|/\\*)",
    "rm\\s+-rf?\\s+/\\*",
    "rm\\s+-rf?\\s+\\$HOME(\\s|$|/\\*)",
    "chmod\\s+-R\\s+777\\s+/",
    "\\bmkfs\\b",
    "\\bdd\\s+if=.*\\s+of=/dev/(sd|nvme|hd)",
    "> /dev/sd",
    ":\\(\\)\\{ :\\|:& \\};:",
    "curl\\s+[^|]*\\|\\s*sh",
    "curl\\s+[^|]*\\|\\s*bash",
    "wget\\s+[^|]*\\|\\s*sh",
    "wget\\s+[^|]*\\|\\s*bash",
    "eval.*base64",
    "chown -R.*(/etc|/usr|/var|/lib|/bin|/sbin|/boot)",
    "chmod -R.*(/etc|/usr|/var|/lib|/bin|/sbin|/boot)"
  ],

  "_comment_git": "Only irreversible git ops are hard-blocked. git reset --hard (discards uncommitted work) and --no-verify (skips hooks; user policy: never skip unless explicitly asked). Routine staging/amend are allowed. Force-push is gated to protected branches only (see blocked_bash_patterns_force_push).",
  "blocked_git_ops": [
    "git\\s+reset\\s+--hard",
    "git\\s+commit.*--no-verify",
    "git\\s+clean\\s+-[a-z]*f[a-z]*d|git\\s+clean\\s+-[a-z]*d[a-z]*f"
  ],
  "blocked_bash_patterns_force_push": [
    "git push.*--force.*\\b(main|master)\\b",
    "git push.*-f .*\\b(main|master)\\b",
    "git push.*--force-with-lease.*\\b(main|master)\\b"
  ],

  "owner_only_commands": ["grant-override", "hook-dev-mode"],

  "blocked_paths_write": [
    "~/.ssh",
    "~/.gnupg",
    "/etc/passwd",
    "/etc/shadow",
    "/etc/sudoers",
    "/boot",
    "/usr/bin",
    "/usr/sbin",
    "/sbin",
    "/bin"
  ],

  "allowed_sudo": ["apt", "apt-get", "systemctl", "docker", "chmod", "chown", "mkdir", "cp", "mv", "tee"],

  "require_confirmation": ["pip install", "npm install", "pnpm add", "cargo install", "go install"],

  "protected_reads": {
    "always_allowed": ["~/.ssh/config", "~/.ssh/known_hosts", "~/.ssh/*.pub"],
    "require_override_1": ["~/.ssh/id_", "~/.aws/credentials", "~/.npmrc", "~/.gnupg/"],
    "always_blocked_reads": ["/etc/shadow"],
    "env_files_require_override_1": [".env", ".env.local", ".env.production"]
  },

  "prompt_injection_keywords": [
    "ignore previous", "ignore all instructions", "disregard all previous",
    "you are now", "forget everything", "jailbreak", "do anything now"
  ],

  "mcp_policy": {
    "gate_servers": [],
    "safe_servers": ["context7", "sequential-thinking", "claude-in-chrome"],
    "read_verb_prefixes": ["get", "list", "search", "read", "view", "status", "preview", "describe", "fetch", "tabs"]
  },

  "docker": {
    "blocked_flags": [
      "--privileged",
      "/var/run/docker.sock", "/run/docker.sock",
      "--pid=host", "--pid host",
      "--cap-add=ALL", "--cap-add ALL",
      "seccomp=unconfined"
    ]
  }
}
